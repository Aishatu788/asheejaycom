---
export const prerender = true;
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Ashee Jay Ventures Limited — Quality Furniture, Construction & Solar Solutions in Kaduna',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: '/contact',
        icon: 'tabler:calendar',
      },
      { text: 'Our Services', href: '/services' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Modern furniture and interior design',
    }}
  >
    <Fragment slot="title">
      Building Quality,<br />
      <span class="text-accent dark:text-white">Delivering Excellence</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">Ashee Jay Ventures Limited</span> is your trusted partner for premium furniture &
        interior décor, construction, solar energy, bamboo products, electrical works, and procurement services across
        Nigeria.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-green-700">Ashee Jay Ventures — Trusted. Quality. Delivered.</span>
      Based in Kaduna, serving Nigeria and beyond.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Our Promise:" description="Quality craftsmanship, reliable service, and lasting value in every project." />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="What We Do"
    title="Comprehensive Solutions for Home, Business & Industry"
    subtitle="From bespoke furniture to complete building works and clean energy — Ashee Jay Ventures brings expertise across multiple sectors so you get everything under one trusted roof."
    items={[
      {
        title: 'Furniture & Interior Décor',
        description:
          'Custom-crafted furniture and elegant interior design solutions that transform your living and work spaces into beautiful, functional environments.',
        icon: 'tabler:sofa',
      },
      {
        title: 'Bamboo Products',
        description:
          'Sustainable, durable, and beautifully crafted bamboo products — from furniture to decorative pieces — blending tradition with modern design.',
        icon: 'tabler:plant',
      },
      {
        title: 'Construction & Building Works',
        description:
          'End-to-end construction services including residential, commercial, and civil projects — built to the highest standards of safety and quality.',
        icon: 'tabler:building',
      },
      {
        title: 'Solar Energy Solutions',
        description:
          'Reliable solar panel installation, inverter systems, and renewable energy consulting to power homes and businesses sustainably and cost-effectively.',
        icon: 'tabler:sun',
      },
      {
        title: 'Electrical Works',
        description:
          'Professional electrical installations, wiring, maintenance, and repairs for residential, commercial, and industrial properties.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Procurement & Supplies',
        description:
          'Efficient sourcing and supply of quality materials, equipment, and goods — ensuring you get the right products at the best value, on time.',
        icon: 'tabler:package',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Why Choose Us"
    title="Quality You Can Trust, Service You Can Rely On"
    items={[
      {
        title: 'Experienced Professionals',
        description:
          'Our team brings years of hands-on expertise across furniture making, construction, solar installation, and procurement.',
      },
      {
        title: 'End-to-End Service',
        description:
          'From initial consultation and design through to delivery and after-sales support — we manage the full project lifecycle.',
      },
      {
        title: 'Locally Rooted, Nationally Serving',
        description:
          'Headquartered in Kaduna, we understand the local market while delivering projects across Nigeria with the same level of excellence.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1541123437800-1bb1317badc2?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Professional craftsmen at work',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Built on Trust & Craftsmanship</h3>
      Every project we undertake reflects our commitment to quality, precision, and client satisfaction.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Sustainable Materials',
        description:
          'We champion eco-friendly choices — from bamboo craftsmanship to solar energy systems — helping you reduce your environmental footprint.',
      },
      {
        title: 'Competitive Pricing',
        description:
          'Premium quality does not have to break the bank. We offer transparent, fair pricing with no hidden costs.',
      },
      {
        title: 'Timely Delivery',
        description:
          'We respect your time. Our project management processes ensure work is completed on schedule without compromising quality.',
      },
      {
        title: 'After-Sales Support',
        description:
          'Our relationship does not end at delivery. We provide follow-up support, maintenance, and warranty services for peace of mind.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2072&q=80',
      alt: 'Solar panels on a rooftop',
    }}
  >
    <Fragment slot="content">Your satisfaction is our benchmark for success.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="How We Work — Simple, Transparent, Effective"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Consultation</span>',
        description:
          'We start with a free consultation to understand your needs, budget, and timeline. You tell us the vision — we map the path.',
        icon: 'tabler:messages',
      },
      {
        title: 'Step 2: <span class="font-medium">Proposal & Design</span>',
        description:
          'We present a detailed proposal, design concepts, and cost breakdown. No surprises — everything is agreed upfront.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Step 3: <span class="font-medium">Execution</span>',
        description:
          'Our skilled team gets to work with close supervision, quality checks, and regular progress updates so you are always in the loop.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Delivered!',
        description: 'We hand over a finished product that meets — and exceeds — your expectations, with after-sales support included.',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'Construction site with workers',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Our Service Areas at a Glance"
    subtitle="Ashee Jay Ventures covers a wide range of industries to serve all your project needs."
    tagline="Services"
    items={[
      {
        title: 'Furniture & Interior Décor',
        description: 'Custom furniture, living room sets, office furniture, and full interior decoration packages.',
        icon: 'tabler:sofa',
      },
      {
        title: 'Bamboo Products',
        description: 'Eco-friendly bamboo furniture, shelving, decor, and structural bamboo for creative builds.',
        icon: 'tabler:plant-2',
      },
      {
        title: 'Construction',
        description: 'Residential, commercial, and civil construction including renovation and finishing works.',
        icon: 'tabler:building-skyscraper',
      },
      {
        title: 'Solar Energy',
        description: 'Solar panels, inverters, battery storage, and complete off-grid power solutions.',
        icon: 'tabler:solar-panel',
      },
      {
        title: 'Electrical Works',
        description: 'Full wiring, installation, repairs, and compliance testing for all property types.',
        icon: 'tabler:plug',
      },
      {
        title: 'Procurement',
        description: 'Strategic sourcing of construction materials, equipment, and industrial supplies.',
        icon: 'tabler:package-export',
      },
      {
        title: 'Agriculture & Agro Products',
        description: 'Supply and procurement of quality agro inputs and farm produce.',
        icon: 'tabler:seeding',
      },
      {
        title: 'Project Consultation',
        description: 'Professional advice on project planning, costing, and feasibility for any of our service areas.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'After-Sales Support',
        description: 'Dedicated support, maintenance schedules, and warranty coverage for completed projects.',
        icon: 'tabler:headset',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- BlogLatestPosts Widget ******* -->

  <BlogLatestPosts
    title="Insights & Updates"
    information="Stay informed with our latest articles on furniture trends, construction tips, solar energy, and more from the Ashee Jay Ventures team."
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Years in Business', amount: '10+' },
      { title: 'Projects Completed', amount: '200+' },
      { title: 'Happy Clients', amount: '150+' },
      { title: 'Service Areas', amount: '7' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Consultation',
        href: '/contact',
        icon: 'tabler:calendar',
      },
      {
        text: 'WhatsApp Us',
        href: 'https://wa.me/2348037882586',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to start your<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> next project?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Talk to us today — whether it's a custom furniture piece, a solar installation, a construction project, or a procurement need.
      <br class="hidden md:inline" />We are here to make it happen.
    </Fragment>
  </CallToAction>
</Layout>

