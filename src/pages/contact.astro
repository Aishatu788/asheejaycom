---
export const prerender = true;
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Us',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contact" title="Let's Work Together!" />

  <!-- Contact Form ******************* -->
  <section class="px-4 sm:px-6 max-w-3xl mx-auto py-12 md:py-16">
    <div class="mb-8 text-center">
      <p class="text-xl text-muted dark:text-slate-400">
        Fill in the form below and we will get back to you within 24 business hours.
      </p>
    </div>

    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      class="space-y-6"
    >
      <input type="hidden" name="access_key" value="f0c74af0-1452-4265-a93f-7afd2b541085" />
      <input type="hidden" name="subject" value="New enquiry from Ashee Jay Ventures website" />
      <input type="hidden" name="redirect" value="/contact?success=true" />
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">Full Name <span class="text-red-500">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="John Doe"
            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-slate-800 text-gray-900 dark:text-white"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">Email Address <span class="text-red-500">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-slate-800 text-gray-900 dark:text-white"
          />
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">Phone Number</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="+234 800 000 0000"
            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-slate-800 text-gray-900 dark:text-white"
          />
        </div>
        <div>
          <label for="service" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">Service of Interest</label>
          <select
            id="service"
            name="service"
            class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-slate-800 text-gray-900 dark:text-white"
          >
            <option value="">Select a service…</option>
            <option>Furniture & Interior Décor</option>
            <option>Bamboo Products</option>
            <option>Construction & Building Works</option>
            <option>Solar Energy Solutions</option>
            <option>Electrical Works</option>
            <option>Procurement & Supplies</option>
            <option>Agriculture & Agro Products</option>
            <option>Other / General Enquiry</option>
          </select>
        </div>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1">Message <span class="text-red-500">*</span></label>
        <textarea
          id="message"
          name="message"
          required
          rows={6}
          placeholder="Tell us about your project or enquiry…"
          class="w-full px-4 py-3 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent bg-white dark:bg-slate-800 text-gray-900 dark:text-white resize-none"
        ></textarea>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 items-center">
        <button
          type="submit"
          class="btn btn-primary w-full sm:w-auto px-8 py-3 text-base font-semibold"
        >
          Send Message
        </button>

        <a
          href="https://wa.me/2348037882586"
          target="_blank"
          rel="noopener noreferrer"
          class="btn w-full sm:w-auto px-8 py-3 text-base font-semibold flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white border-green-500 hover:border-green-600 dark:bg-green-600 dark:hover:bg-green-700"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Chat on WhatsApp
        </a>
      </div>

      <p class="text-sm text-muted dark:text-slate-400">
        By submitting this form, you agree to the collection and use of your information to respond to your enquiry.
      </p>
    </form>

    {/* Success message shown after redirect */}
    <script is:inline>
      if (new URLSearchParams(window.location.search).get('success') === 'true') {
        document.addEventListener('DOMContentLoaded', function () {
          const banner = document.createElement('div');
          banner.className = 'fixed top-6 left-1/2 -translate-x-1/2 bg-green-600 text-white px-6 py-3 rounded-lg shadow-lg z-50 text-center font-medium';
          banner.textContent = '✅ Message sent! We will be in touch within 24 hours.';
          document.body.appendChild(banner);
          setTimeout(() => banner.remove(), 6000);
        });
      }
    </script>
  </section>

  <!-- Features2 Widget ************** -->

  <Features2
    title="Other Ways to Reach Us"
    items={[
      {
        title: 'Call or WhatsApp',
        description: '+234 803 788 2586 — We respond quickly on WhatsApp during business hours.',
        icon: 'tabler:phone',
      },
      {
        title: 'Email',
        description: '<a href="mailto:meetasheejay@gmail.com" class="text-primary underline">meetasheejay@gmail.com</a> — For detailed enquiries and project briefs.',
        icon: 'tabler:mail',
      },
      {
        title: 'Head Office',
        description: 'No.1 Aliyu Turaki Road, Kaduna, Kaduna State, Nigeria.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Instagram',
        description: '<a href="https://www.instagram.com/asheejay_furniture_ventures" target="_blank" class="text-primary underline">@asheejay_furniture_ventures</a> — Follow us for project updates and inspiration.',
        icon: 'tabler:brand-instagram',
      },
      {
        title: 'Facebook',
        description: '<a href="https://www.facebook.com/Ashee-Jay" target="_blank" class="text-primary underline">Ashee Jay</a> — Like our page for news and offers.',
        icon: 'tabler:brand-facebook',
      },
      {
        title: 'Business Hours',
        description: 'Monday – Friday: 8:00 AM – 6:00 PM &nbsp;|&nbsp; Saturday: 9:00 AM – 3:00 PM',
        icon: 'tabler:clock',
      },
    ]}
  />
</Layout>
