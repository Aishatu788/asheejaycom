---
export const prerender = true;
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Us',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About Ashee Jay Ventures"
    image={{
      src: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Construction and building works',
    }}
  >
    <Fragment slot="title">
      Building a Better Nigeria —<br />
      <span class="text-accent dark:text-white">One Project at a Time</span>
    </Fragment>

    <Fragment slot="subtitle">
      Ashee Jay Ventures Limited is a multi-sector company headquartered in Kaduna, Nigeria. We specialize in
      furniture & interior décor, bamboo products, construction, solar energy, electrical works, and procurement —
      delivering quality and value across every engagement.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Ashee Jay Ventures by the Numbers"
    stats={[
      { title: 'Years in Business', amount: '10+' },
      { title: 'Projects Completed', amount: '200+' },
      { title: 'Happy Clients', amount: '150+' },
      { title: 'Service Areas', amount: '7' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="What We Do"
    subtitle="Our portfolio of services spans multiple industries, allowing us to serve diverse client needs under one trusted brand."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Furniture & Interior Décor',
        description:
          'Custom-made furniture and full interior decoration services for homes, offices, and commercial spaces.',
        icon: 'tabler:sofa',
      },
      {
        title: 'Bamboo Products',
        description:
          'Handcrafted bamboo furniture and decorative pieces that combine sustainability with elegant design.',
        icon: 'tabler:plant',
      },
      {
        title: 'Construction & Building Works',
        description:
          'Complete construction services — from residential buildings to commercial developments and renovation projects.',
        icon: 'tabler:building',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Solar Energy Solutions',
        description:
          'Installation of solar panels, inverters, and battery systems for clean, reliable, and affordable power.',
        icon: 'tabler:sun',
      },
      {
        title: 'Electrical Works',
        description:
          'Professional electrical installation, maintenance, and repairs for all types of properties.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Procurement & Supplies',
        description:
          'Strategic sourcing of materials, equipment, and goods with efficient delivery and competitive pricing.',
        icon: 'tabler:package',
      },
      {
        title: 'Agriculture & Agro Products',
        description:
          'Supply and procurement of quality agricultural inputs and farm produce across Nigeria.',
        icon: 'tabler:seeding',
      },
      {
        title: 'Project Consultation',
        description:
          'Expert advice on project planning, costing, material selection, and feasibility for your next venture.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'After-Sales Support',
        description:
          'Dedicated post-project support, maintenance schedules, and warranty coverage for all our services.',
        icon: 'tabler:headset',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Furniture and interior design',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Our Core Values"
    subtitle="Everything we do at Ashee Jay Ventures is guided by a set of values that put the client first and quality above all else."
    items={[
      {
        title: 'Quality Without Compromise',
        description:
          'We source the best materials and employ skilled professionals to ensure every project meets the highest standards.',
      },
      {
        title: 'Integrity & Transparency',
        description:
          'We are honest about costs, timelines, and capabilities. You will always know exactly where your project stands.',
      },
      {
        title: 'Client-Centred Service',
        description:
          'Your vision is our brief. We listen carefully, adapt to your needs, and go the extra mile to exceed expectations.',
      },
      {
        title: 'Sustainability',
        description:
          'From bamboo craftsmanship to solar energy solutions, we actively promote eco-friendly choices that benefit people and planet.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Our Achievements"
    subtitle="A track record built on hard work, trusted relationships, and consistent delivery across Nigeria."
    isReversed={true}
    callToAction={{
      text: 'See Our Projects',
      href: '/projects',
    }}
    items={[
      {
        title: 'Serving clients across multiple states',
        description: 'From Kaduna to Lagos, Abuja, and beyond — our work speaks across geographies.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Trusted by homeowners, businesses & institutions',
        description:
          'Our client base spans private homeowners, SMEs, government projects, and large commercial developers.',
        icon: 'tabler:building-community',
      },
      {
        title: 'Certified professionals across every service area',
        description:
          'Our team holds relevant technical certifications and undergoes continuous training in their respective fields.',
        icon: 'tabler:award',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Find Us"
    tagline="Our Location"
    columns={2}
    items={[
      {
        title: 'Head Office — Kaduna',
        description: 'No.1 Aliyu Turaki Road, Kaduna, Kaduna State, Nigeria.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Get in Touch',
        description: 'Call: +234 803 788 2586 &nbsp;|&nbsp; Email: meetasheejay@gmail.com',
        icon: 'tabler:phone',
      },
    ]}
  />
</Layout>
