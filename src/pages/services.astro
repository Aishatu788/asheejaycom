---
export const prerender = true;
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Products & Services',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Products & Services"
    title="Everything You Need, Under One Roof"
    subtitle="Ashee Jay Ventures offers a comprehensive range of products and services across furniture, construction, energy, and procurement — all delivered with the same commitment to quality."
    actions={[{ variant: 'primary', text: 'Book a Consultation', href: '/contact', icon: 'tabler:calendar' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Ashee Jay Ventures services',
    }}
  />

  <!-- Furniture Section -->
  <Content
    id="furniture"
    isReversed
    tagline="Service 01"
    title="Furniture & Interior Décor"
    items={[
      {
        title: 'Custom-Made Furniture',
        description: 'Beds, sofas, dining sets, wardrobes, office desks and more — designed and built to your specifications.',
        icon: 'tabler:sofa',
      },
      {
        title: 'Full Interior Decoration',
        description: 'End-to-end interior design and fit-out services for homes, offices, hotels, and commercial spaces.',
        icon: 'tabler:palette',
      },
      {
        title: 'Space Planning & Consultation',
        description: 'Professional layout advice to maximise the functionality and aesthetics of any space.',
        icon: 'tabler:layout',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Furniture and interior decor',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Transform Your Space</h3>
      We blend artistry with craftsmanship to deliver furniture and interiors that are beautiful, durable, and tailored to your lifestyle.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Bamboo Section -->
  <Content
    id="bamboo"
    isAfterContent
    tagline="Service 02"
    title="Bamboo Products"
    items={[
      {
        title: 'Bamboo Furniture',
        description: 'Eco-friendly chairs, tables, shelving units, and beds crafted from sustainably sourced bamboo.',
        icon: 'tabler:plant',
      },
      {
        title: 'Bamboo Decorative Pieces',
        description: 'Carvings, wall art, lampshades, and bespoke décor items that add a natural, unique touch to any space.',
        icon: 'tabler:star',
      },
      {
        title: 'Structural Bamboo',
        description: 'Bamboo poles and panels for architectural applications, landscaping, and creative builds.',
        icon: 'tabler:building',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1563861826100-9cb868fdbe1c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Bamboo products',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Natural. Sustainable. Beautiful.</h3>
      Bamboo is one of the most versatile and eco-friendly materials available. Our craftsmen bring out its full potential.
    </Fragment>
  </Content>

  <!-- Construction Section -->
  <Content
    id="construction"
    isReversed
    isAfterContent
    tagline="Service 03"
    title="Construction & Building Works"
    items={[
      {
        title: 'Residential Construction',
        description: 'New builds, extensions, and renovations — from foundations to finishing, built to last.',
        icon: 'tabler:home',
      },
      {
        title: 'Commercial & Institutional',
        description: 'Office blocks, schools, warehouses, and commercial facilities constructed to spec and on schedule.',
        icon: 'tabler:building-skyscraper',
      },
      {
        title: 'Renovation & Finishing Works',
        description: 'Tiling, plastering, painting, roofing, landscaping, and all finishing trades to complete your property.',
        icon: 'tabler:hammer',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Construction and building works',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Built Right, Built to Last</h3>
      Our construction team delivers every project on time and to specification, from single-room additions to full commercial developments.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Solar Section -->
  <Content
    id="solar"
    isAfterContent
    tagline="Service 04"
    title="Solar Energy Solutions"
    items={[
      {
        title: 'Solar Panel Installation',
        description: 'Grid-tied and off-grid solar systems for homes and businesses of any size.',
        icon: 'tabler:solar-panel',
      },
      {
        title: 'Inverter & Battery Systems',
        description: 'Complete power backup solutions including inverter selection, battery banks, and charge controllers.',
        icon: 'tabler:battery-charging',
      },
      {
        title: 'Energy Audit & Consultation',
        description: 'Professional assessment of your energy needs and recommendations for the most cost-effective solar solution.',
        icon: 'tabler:chart-bar',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2072&q=80',
      alt: 'Solar energy solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Power Your Future with the Sun</h3>
      Reduce your electricity bills, gain energy independence, and contribute to a cleaner environment with our solar solutions.
    </Fragment>
  </Content>

  <!-- Electrical Section -->
  <Content
    id="electrical"
    isReversed
    isAfterContent
    tagline="Service 05"
    title="Electrical Works"
    items={[
      {
        title: 'Full Property Wiring',
        description: 'New installations and rewiring for residential, commercial, and industrial properties done safely and to code.',
        icon: 'tabler:plug',
      },
      {
        title: 'Maintenance & Repairs',
        description: 'Fault diagnosis, repairs, and preventive maintenance to keep your electrical systems running reliably.',
        icon: 'tabler:tool',
      },
      {
        title: 'Lighting & Control Systems',
        description: 'Indoor and outdoor lighting design, installation, and smart control systems for any property type.',
        icon: 'tabler:bulb',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1621905251189-08b45d6a269e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1738&q=80',
      alt: 'Electrical works',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Safe, Reliable Electrical Services</h3>
      Our certified electricians handle all electrical work with professionalism and strict adherence to safety standards.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Procurement Section -->
  <Content
    id="procurement"
    isAfterContent
    tagline="Service 06"
    title="Procurement & Supplies"
    items={[
      {
        title: 'Construction Materials',
        description: 'Cement, steel, tiles, timber, roofing sheets, and all building materials sourced at competitive prices.',
        icon: 'tabler:package',
      },
      {
        title: 'Equipment & Machinery',
        description: 'Industrial and construction equipment procurement with logistics support across Nigeria.',
        icon: 'tabler:crane',
      },
      {
        title: 'Office & Facility Supplies',
        description: 'End-to-end supply of office furniture, stationery, cleaning materials, and facility management goods.',
        icon: 'tabler:shopping-cart',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1553413077-190dd305871c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Procurement and supplies',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">The Right Materials, At the Right Price</h3>
      We leverage our supplier network to source quality goods efficiently, saving you time, cost, and hassle.
    </Fragment>
  </Content>

  <!-- Agriculture Section -->
  <Features2
    id="agriculture"
    tagline="Service 07"
    title="Agriculture & Agro Products"
    subtitle="We supply and procure quality agricultural inputs and farm produce to support Nigeria's growing agribusiness sector."
    columns={3}
    items={[
      {
        title: 'Agro Inputs',
        description: 'Fertilisers, seeds, pesticides, and farm chemicals sourced from trusted suppliers.',
        icon: 'tabler:seeding',
      },
      {
        title: 'Farm Produce Supply',
        description: 'Bulk supply of grains, tubers, and other farm produce for businesses, institutions, and traders.',
        icon: 'tabler:basket',
      },
      {
        title: 'Agricultural Consultation',
        description: 'Guidance on sourcing, logistics, and market access for farmers and agribusiness operators.',
        icon: 'tabler:clipboard-list',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Consultation',
        href: '/contact',
        icon: 'tabler:calendar',
      },
      {
        text: 'WhatsApp Us',
        href: 'https://wa.me/2348037882586',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
    title="Ready to get started?"
    subtitle="Whether you need a full interior fit-out, a solar installation, or a procurement solution — we have you covered. Reach out today for a free consultation."
  />
</Layout>
