---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Ashee Jay Ventures brand colors: forest green + amber gold */
    --aw-color-primary: rgb(45 106 79);     /* #2D6A4F — deep forest green */
    --aw-color-secondary: rgb(27 67 50);    /* #1B4332 — dark green */
    --aw-color-accent: rgb(233 162 39);     /* #E9A227 — amber gold */

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(64 145 108);    /* lighter green for dark mode */
    --aw-color-secondary: rgb(45 106 79);
    --aw-color-accent: rgb(233 162 39);     /* amber gold stays consistent */

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: black;
      color: snow;
    }
  }
</style>
